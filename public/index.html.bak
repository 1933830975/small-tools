<div class="modal" id="modal">
  <div id="mTitle"></div>
  <input id="mInput" placeholder="请输入内容（多参数用英文逗号分隔）">
  <button class="btn" id="run">执行</button>
</div>
<div class="toast" id="toast"></div>
<!-- 全局提示框/结果框/空标签（动态生成的容器提前创建，避免重复查询） -->
<div class="toast-global" id="toastGlobal"></div>
<div class="no-result" id="noResult">未找到相关工具</div>
<script>
// ========== 全局常量/变量 ==========
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('overlay');
const modal   = document.getElementById('modal');
const toast   = document.getElementById('toast');
const toastGlobal = document.getElementById('toastGlobal');
const noResult = document.getElementById('noResult');
let currTool  = ''; // 原有工具标识
let currentTool = ''; // 网络工具标识
let isRunning = false; // 防止重复执行
let inputHistory = JSON.parse(localStorage.getItem('input_history')||'[]');
let histIndex = -1;
// 工具输入占位符提示
const toolPlaceholder = {
  '十进制转二进制': '请输入数字',
  '八进制转二进制': '请输入数字',
  '十六进制转二进制': '请输入数字',
  '最大数计算': '数字用英文逗号分隔，如10,20,30',
  '求和计算': '数字用英文逗号分隔，如10,20,30',
  '税率计算': '金额,税率，如1000,5',
  '利息计算': '本金,利率,期数，如10000,3,12',
  '年龄计算': '请输入出生年份，如2008',
  '银行卡号校验': '请输入银行卡号',
  '车牌号校验': '请输入车牌号'
};

// ========== 基础工具函数 ==========
// 基础提示（底部）
function showToast(m){
  toast.textContent = m;
  toast.classList.add('show');
  setTimeout(()=>toast.classList.remove('show'), 1800);
}
// 全局提示（中间，复制/操作成功）
function showToastGlobal(msg) {
  toastGlobal.textContent = msg;
  toastGlobal.classList.add('show');
  setTimeout(() => toastGlobal.classList.remove('show'), 1200);
}
// 关闭所有弹窗/侧边栏
function closeAll(){
  sidebar.classList.remove('show');
  overlay.classList.remove('show');
  modal.classList.remove('show');
}
// 结果展示（统一）
function showResult(text) {
  let box = document.querySelector('.result-output') || document.createElement('div');
  box.className = 'result-output';
  box.textContent = text;
  document.getElementById('run').after(box);
}
// MD5加密
function md5(s){
  let l=Math.pow(2,32),a=0x67452301,b=0xEFCDAB89,c=0x98BADCFE,d=0x10325476,f=e=>{
    let n=[],i,j;
    for(i=0;i<64;i++)n[i]=(l+Math.abs(Math.sin(i+1)))>>>0;
    s=unescape(encodeURIComponent(s));
    let t=[],len=s.length;
    for(i=0;i<len-3;i+=4)t.push(s.charCodeAt(i)|(s.charCodeAt(i+1)<<8)|(s.charCodeAt(i+2)<<16)|(s.charCodeAt(i+3)<<24));
    for(j=len*8;i=t.length;t[i++]=0);
    t[t.length-1]|=j;
    for(i=0;i<t.length;i+=16){
      let o=a,p=b,q=c,r=d;
      for(j=0;j<64;j++){
        let g,k,m=t[i+((16*j)/64)|0],F;
        if(j<16){F=(b&c)|((~b)&d);g=j}else if(j<32){F=(d&b)|((~d)&c);g=(5*j+1)%16}else if(j<48){F=b^c^d;g=(3*j+5)%16}else{F=c^(b|~d);g=(7*j)%16}
        F=(F+a+n[j]+m)|0;
        k=(b<<(F=(F<<7)|(F>>>25)))|(b>>>(32-F));
        a=d;d=c;c=k;b=k
      }
      a=(a+o)|0;b=(b+p)|0;c=(c+q)|0;d=(d+r)|0
    }
    return [a,b,c,d].map(x=>{
      let s='';
      for(i=0;i<4;i++)s+=((x>>>8*i)&0xFF).toString(16).padStart(2,'0');
      return s
    }).join('')
  };
  return f(s).toLowerCase()
}
// UUID生成
function genUUID(){
  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,c=>{
    let r=Math.random()*16|0,v=c=='x'?r:(r&0x3|0x8)
    return v.toString(16)
  })
}

// ========== 原有工具接口/页面交互 ==========
// 加载最近使用
async function loadMem(){
  const d = await (await fetch('/api/memory')).json();
  document.getElementById('memList').innerHTML = d.data.map(i=>`<div class="mem-item">${i.tool}</div>`).join('');
}
// 加载使用统计
async function loadStat(){
  const d = await (await fetch('/api/stats')).json();
  const t = Object.values(d.data).reduce((a,b)=>a+b,0);
  let h = `<div class="stat"><span>总次数</span><span>${t}</span></div>`;
  Object.entries(d.data).forEach(([k,v])=>{
    h+=`<div class="stat"><span>${k}</span><span>${v}</span></div>`;
  });
  document.getElementById('statList').innerHTML = h;
}
// 加载收藏
async function loadFav(){
  const d = await (await fetch('/api/favorites')).json();
  if(d.data.length===0){
    document.getElementById('favList').innerHTML = '暂无收藏，长按工具收藏';
    return;
  }
  document.getElementById('favList').innerHTML = d.data.map(i=>`
    <span class="fav-tag">${i}<span class="del" onclick="delFav('${i}')">×</span></span>
  `).join('');
}
// 删除收藏
window.delFav = async (name)=>{
  await fetch('/api/fav',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({name,act:'del'})
  });
  loadFav();
  showToast('已取消收藏');
}
// 打开原有工具
function openToolOrigin(name){
  currTool = name;
  currentTool = ''; // 清空网络工具标识
  document.getElementById('mTitle').textContent = name;
  document.getElementById('mInput').value = '';
  document.getElementById('mInput').placeholder = toolPlaceholder[name] || '请输入内容（多参数用英文逗号）';
  modal.classList.add('show');
  overlay.classList.add('show');
  // 工具高亮
  document.querySelectorAll('.card').forEach(c => c.classList.remove('active'));
  document.querySelectorAll('.card').forEach(c => {
    if(c.textContent.trim() === name) c.classList.add('active');
  });
  // 工具使用次数统计
  countToolUse(name);
}
// 原有工具执行
async function runToolOrigin(){
  const c = document.getElementById('mInput').value;
  const res = await fetch('/api/run',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({tool:currTool,c})
  });
  const d = await res.json();
  showToast(d.data || d.msg);
  // 保存输入历史
  saveInputHistory(c);
  closeAll();
  loadMem();
}

// ========== 新增优化功能 ==========
// 1. 工具使用次数统计
function countToolUse(name) {
  let count = localStorage.getItem('tool_count_' + name) || 0;
  count = parseInt(count) + 1;
  localStorage.setItem('tool_count_' + name, count);
}
// 2. 保存输入历史
function saveInputHistory(v) {
  v = v.trim();
  if(v && !inputHistory.includes(v)){
    inputHistory.unshift(v);
    inputHistory = inputHistory.slice(0,20);
    localStorage.setItem('input_history',JSON.stringify(inputHistory));
  }
  histIndex = -1;
}
// 3. 一键清空最近使用
function clearRecent() {
  if(confirm('确定清空所有最近使用记录吗？')) {
    localStorage.removeItem('recent_tools');
    document.getElementById('memList').innerHTML = '<div>暂无最近使用</div>';
    showToastGlobal('已清空最近使用');
  }
}
// 4. 一键清空收藏
function clearFavorite() {
  if(confirm('确定清空所有收藏工具吗？')) {
    localStorage.removeItem('favorite_tools');
    document.getElementById('favList').innerHTML = '<div>暂无收藏</div>';
    showToastGlobal('已清空收藏');
  }
}
// 5. 清空所有本地数据
function clearAllData() {
  if(confirm('确定清空所有数据？收藏/记录/次数将全部重置')){
    localStorage.clear();
    location.reload();
  }
}
// 6. 返回顶部功能
function initBackTop() {
  const backTop = document.createElement('div');
  backTop.className = 'back-top';
  backTop.innerHTML = '↑';
  document.body.appendChild(backTop);
  backTop.onclick = () => window.scrollTo(0,0);
  window.addEventListener('scroll', () => {
    backTop.classList.toggle('show', window.scrollY > 300);
  });
}
// 7. 搜索框功能
function initSearch() {
  const searchWrap = document.createElement('div');
  searchWrap.className = 'search-box';
  const searchInput = document.createElement('input');
  searchInput.className = 'search-input';
  searchInput.placeholder = '搜索工具名称...';
  searchWrap.appendChild(searchInput);
  document.body.insertBefore(searchWrap, document.body.firstChild);
  // 搜索逻辑
  searchInput.oninput = function() {
    const key = this.value.toLowerCase();
    document.querySelectorAll('.card').forEach(card => {
      const name = card.textContent.toLowerCase();
      card.style.display = name.includes(key) ? 'block' : 'none';
    });
    // 无结果提示
    const total = document.querySelectorAll('.card').length;
    const hidden = document.querySelectorAll('.card[style="display: none;"]').length;
    noResult.style.display = total === hidden ? 'block' : 'none';
    document.querySelector('.main').appendChild(noResult);
  };
}
// 8. 分类快捷标签
function initCatTab() {
  const catTab = document.createElement('div');
  catTab.className = 'category-tab';
  const cats = ['全部','常用','逆向','系统','网络','其他'];
  cats.forEach(c => {
    const s = document.createElement('span');
    s.textContent = c;
    s.onclick = () => {
      document.querySelectorAll('.category-tab span').forEach(t=>t.classList.remove('active'));
      s.classList.add('active');
      showToast('切换至：'+c);
    };
    catTab.appendChild(s);
  });
  document.querySelector('.search-box').after(catTab);
}
// 9. 主题切换（手动+系统+记忆）
function initTheme() {
  // 手动深色/浅色切换按钮
  const themeBtn = document.createElement('div');
  themeBtn.className = 'theme-toggle';
  themeBtn.textContent = '🌙';
  document.body.appendChild(themeBtn);
  themeBtn.onclick = () => {
    document.body.classList.toggle('dark');
    localStorage.setItem('dark_mode', document.body.classList.contains('dark'));
    themeBtn.textContent = document.body.classList.contains('dark') ? '☀️' : '🌙';
  };
  // 记住手动深色模式
  if(localStorage.getItem('dark_mode') === 'true') {
    document.body.classList.add('dark');
    themeBtn.textContent = '☀️';
  }
  // 系统深色模式适配
  const media = window.matchMedia('(prefers-color-scheme: dark)');
  media.addEventListener('change', e => {
    if(!localStorage.getItem('dark_mode')){
      document.body.classList.toggle('system-dark', e.matches);
    }
  });
  // 自动夜间模式（22:00-07:00）
  const hour = new Date().getHours();
  if((hour>=22 || hour<=7) && !localStorage.getItem('dark_mode')) {
    document.body.classList.add('dark');
    themeBtn.textContent = '☀️';
  }
  // 自定义主题记忆
  const savedTheme = localStorage.getItem('toolboxTheme');
  if (savedTheme) {
    document.body.className = 'theme-' + savedTheme;
  }
}
// 10. 版本信息+长按清空所有数据
function initVersion() {
  const ver = document.createElement('div');
  ver.className = 'version-info';
  ver.textContent = '工具箱 v2.1';
  ver.onclick=()=>showToastGlobal('多功能工具箱 · 2026优化版');
  document.body.appendChild(ver);
  // 长按版本按钮清空所有数据
  let pressTimer = null;
  ver.addEventListener('touchstart',()=>{
    pressTimer = setTimeout(clearAllData,1500);
  });
  ver.addEventListener('touchend',()=>clearTimeout(pressTimer));
  ver.addEventListener('touchmove',()=>clearTimeout(pressTimer));
}
// 11. 网络工具切换
function openToolEx(type, tip) {
  currentTool = type;
  currTool = ''; // 清空原有工具标识
  document.getElementById('mInput').value = '';
  document.getElementById('mInput').placeholder = tip;
  document.getElementById('mTitle').textContent = tip.split('：')[0];
  modal.classList.add('show');
  overlay.classList.add('show');
  showToastGlobal('已切换：' + tip.split('：')[0]);
}
// 12. 网络工具面板
function initNetToolPanel() {
  const wrap = document.createElement('div');
  wrap.className = 'tool-panel';
  const tools = [
    { t: 'myip', n: '本机IP', tip: '无需输入，直接执行' },
    { t: 'proxy', n: '代理检测', tip: '无需输入，直接执行' },
    { t: 'ipposi', n: 'IP精准定位', tip: '输入IP，不输入查本机' },
    { t: 'ipblack', n: 'IP黑名单', tip: '输入要检测的IP' },
    { t: 'ping', n: 'Ping测试', tip: '输入IP/域名' },
    { t: 'dns', n: 'DNS解析', tip: '输入域名' },
    { t: 'pollute', n: '域名污染', tip: '输入域名' },
    { t: 'whois', n: 'Whois查询', tip: '输入域名' },
    { t: 'port', n: '端口检测', tip: '格式 IP:端口' },
    { t: 'douyin', n: '抖音UID查询', tip: '输入抖音ID/链接' },
    { t: 'kuaishou', n: '快手ID查询', tip: '输入快手ID/链接' },
    { t: 'phone', n: '手机号归属', tip: '输入手机号' },
    { t: 'idcard', n: '身份证解析', tip: '输入18位身份证' },
    { t: 'md5', n: 'MD5加密', tip: '输入内容' },
    { t: 'base64en', n: 'Base64加密', tip: '输入原文' },
    { t: 'base64de', n: 'Base64解密', tip: '输入密文' },
    { t: 'uuid', n: 'UUID生成', tip: '无需输入' }
  ];
  tools.forEach(i => {
    const btn = document.createElement('button');
    btn.textContent = i.n;
    btn.onclick = () => openToolEx(i.t, i.tip);
    wrap.appendChild(btn);
  });
  document.body.insertBefore(wrap, document.querySelector('.search-box'));
}
// ========== 网络工具核心函数 ==========
// 1. 本机IP
async function getMyIP(){
  let r = await fetch('https://api.ip.sb/geoip')
  let j = await r.json()
  return `IP: ${j.ip}\n地区: ${j.country} ${j.region} ${j.city}\n运营商: ${j.isp}`
}
// 2. Ping测试
async function doPing(host){
  if(!host)return '请输入域名/IP';
  try{
    let r = await fetch(`https://ping.cloudflare-dns.com/promise?host=${host}`)
    let j = await r.json()
    return j.status === 'ok' ? `延迟: ${j.avg}ms` : 'Ping失败';
  }catch(e){
    return `Ping ${host}\n状态：接口演示\n延迟：30ms（可对接真实Ping接口）`;
  }
}
// 3. DNS解析
async function getDNS(domain){
  if(!domain)return '请输入域名';
  let r = await fetch(`https://cloudflare-dns.com/dns-query?name=${domain}&type=A`,{headers:{'accept':'application/dns-json'}})
  let j = await r.json()
  return j.Answer?.map(i=>i.data).join('\n') || '无解析记录'
}
// 4. Whois查询
async function getWhois(domain){
  if(!domain)return '请输入域名';
  let r = await fetch(`https://whois-dev.vercel.app/api/whois?domain=${domain}`)
  return await r.text()
}
// 5. 端口检测
async function testPort(str){
  let [ip,port] = str.split(':')
  if(!ip||!port)return '格式错误，例：1.1.1.1:80'
  let controller = new AbortController()
  setTimeout(()=>controller.abort(),1500)
  try{
    await fetch(`https://portchecker.vercel.app/api/check?ip=${ip}&port=${port}`,{signal:controller.signal})
    return `${ip}:${port} 开放`
  }catch{return `${ip}:${port} 关闭/不可访问`}
}
// 6. 手机号归属地
function getPhone(p){
  if(!/^1[3-9]\d{9}$/.test(p))return '手机号格式错误'
  let pre = p.slice(0,3)
  return `手机号: ${p}\n号段: ${pre}\n归属地: 接口演示，可对接真实API`
}
// 7. 身份证解析
function getIdCard(id){
  if(!/(^\d{18}$)|(^\d{17}(\d|X|x)$)/.test(id))return '身份证格式错误'
  let birth = id.slice(6,10)+'-'+id.slice(10,12)+'-'+id.slice(12,14)
  let sex = id.slice(16,17)%2===0?'女':'男'
  return `身份证: ${id}\n生日: ${birth}\n性别: ${sex}\n归属地: 可对接民政库`
}
// 8. 代理检测
async function checkProxy() {
  const res = await fetch('https://api.ip.sb/geoip');
  const j = await res.json();
  return `本机IP：${j.ip}
地区：${j.country} ${j.region} ${j.city}
ASN：${j.asn}
代理/VPN：${j.proxy || '否'}
`;
}
// 9. IP黑名单检测
async function checkIPBlack(ip) {
  if (!ip) return '请输入要检测的IP';
  const res = await fetch(`https://api.abuseipdb.com/api/v2/check?ipAddress=${ip}`, {
    headers: { 'Key': 'demo', 'Accept': 'application/json' }
  });
  const j = await res.json();
  if (j.errors) return '黑名单检测：接口演示，替换正式Key即可使用';
  return `IP：${ip}
恶意评分：${j.data.abuseConfidenceScore}/100
是否黑名单：${j.data.abuseConfidenceScore > 20 ? '是' : '否'}
所属国家：${j.data.countryCode}
`;
}
// 10. 域名污染检测
async function checkDomainPollute(domain) {
  if (!domain) return '请输入域名';
  const dns1 = await (await fetch(`https://cloudflare-dns.com/dns-query?name=${domain}&type=A`, { headers: { accept: 'application/dns-json' } })).json();
  const dns2 = await (await fetch(`https://dns.google/resolve?name=${domain}&type=A`)).json();
  const a1 = dns1.Answer?.map(i => i.data).join(',') || '无解析记录';
  const a2 = dns2.Answer?.map(i => i.data).join(',') || '无解析记录';
  return `Cloudflare DNS解析：${a1}
Google DNS解析：${a2}
检测结果：${a1 === a2 ? '正常，无污染/劫持' : '疑似被污染/域名劫持'}
`;
}
// 11. 抖音UID查询
async function getDouyinUID(uid) {
  if (!uid) return '请输入抖音ID/主页链接';
  try{
    const res = await fetch(`https://www.iesdouyin.com/api/douyin/user/?unique_id=${uid}`);
    const j = await res.json();
    if (j.code !== 0) return '查询失败，检查抖音ID是否正确';
    return `抖音UID：${j.data.uid}
用户昵称：${j.data.nickname}
抖音ID：${j.data.unique_id}
`;
  }catch(e){
    return '抖音接口访问受限，可更换接口地址';
  }
}
// 12. IP精准定位
async function getIPDetail(ip) {
  if (!ip) ip = 'me';
  const res = await fetch(`https://ipapi.co/${ip}/json/`);
  const j = await res.json();
  if(j.error) return 'IP定位失败，IP地址无效';
  return `IP地址：${j.ip}
所属国家：${j.country_name}
所属地区：${j.region}
所属城市：${j.city}
经纬度：${j.latitude}, ${j.longitude}
网络运营商：${j.org}
时区：${j.timezone}
`;
}
// 13. 快手ID查询
async function getKuaishouInfo(id) {
  if (!id) return '请输入快手ID/主页链接';
  return `快手ID：${id}
查询结果：接口演示版
可对接功能：UID查询/粉丝数/头像/昵称
提示：需申请快手开放平台API密钥
`;
}
// 14. Base64加密
function base64En(str) {
  return btoa(unescape(encodeURIComponent(str)));
}
// 15. Base64解密
function base64De(str) {
  return decodeURIComponent(escape(atob(str)));
}


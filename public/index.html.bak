<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
<title>Cyber Toolbox Max Pro</title>
<style>
/* 所有CSS样式整合+去重+修复冲突，以下是完整样式 */
*{margin:0;padding:0;box-sizing:border-box;font-family:system-ui,Roboto,sans-serif}
body{background:#12141d;color:#e6e9ef;transition:.3s;animation: pageFadeIn 0.5s ease forwards;}
body.theme-pink{background:#19121d}
body.theme-green{background:#121d17}
body.dark{background:#121212;color:#eee;}
body.dark .card{background:#1e1e1e;}
body.dark .sidebar{background:#1a1a1a;}
body.dark .search-input{background:#222;border-color:#333;color:#eee;}
body.dark .category-tab span{background:#2a2a2a;}
body.dark .result-box{background:#1e1e1e;}
body.dark .tool-panel{background:#1a1a1a}
body.dark .result-output{background:#222;color:#eee}
.overlay{position:fixed;inset:0;background:#0006;z-index:40;opacity:0;pointer-events:none;transition:.3s}
.overlay.show{opacity:1;pointer-events:auto}
.sidebar{position:fixed;left:0;top:0;bottom:0;width:260px;background:#1b1e29;z-index:50;transform:translateX(-100%);transition:.3s;padding:24px 16px;overflow-y:auto}
.sidebar.show{transform:translateX(0)}
.sidebar h2{color:#c4a1ff;margin-bottom:24px;font-size:18px}
.sidebar .menu-item{display:flex;align-items:center;gap:12px;padding:12px;border-radius:10px;margin-bottom:8px;cursor:pointer;transition:all 0.2s ease;}
.sidebar .menu-item:hover{background:#c4a1ff1a;transform: translateX(4px);}
.sidebar .close{position:absolute;top:20px;right:16px;width:36px;height:36px;border-radius:50%;background:#252a3a;display:grid;place-items:center;transition:all 0.2s ease;}
.sidebar .close:hover{background:#c4a1ff;color:#000;transform: rotate(90deg);}
.header{position:fixed;top:0;left:0;right:0;height:60px;background:#1b1e29;display:flex;align-items:center;justify-content:space-between;padding:0 16px;z-index:30}
.header .menu{width:40px;height:40px;border-radius:10px;background:#252a3a;display:grid;place-items:center;transition:all 0.2s ease;}
.header .menu:hover{background:#c4a1ff;color:#000;transform: rotate(15deg);}
.main{margin-top:60px;margin-bottom:80px;padding:16px}
.section{margin-bottom:28px}
.section h3{color:#a5b3ff;margin-bottom:12px}
.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.card{background:#202431;border-radius:12px;padding:12px;text-align:center;cursor:pointer;transition:transform 0.2s ease, box-shadow 0.2s ease;}
.card:hover{background:#272b3b;transform: translateY(-2px);box-shadow: 0 4px 10px rgba(0,0,0,0.25);}
.card.active{background:#c4a1ff;color:#000;font-weight: bold;}
.card .name{font-size:13px;margin-top:6px}
.bottom-nav{position:fixed;bottom:0;left:0;right:0;height:70px;background:#1b1e29;display:flex;align-items:center;justify-content:space-around;padding:0 4px;z-index:30}
.bottom-nav .item{display:flex;flex-direction:column;align-items:center;gap:4px;color:#9ca3af;font-size:12px;padding:8px;min-width:64px;transition:transform 0.15s ease;}
.bottom-nav .item.active{color:#c4a1ff}
.bottom-nav .item:active{transform: scale(0.92);}
.theme-switch{display:flex;gap:8px;margin-top:16px}
.theme-btn{width:32px;height:32px;border-radius:50%;transition:all 0.2s ease;}
.theme-btn:hover{transform: scale(1.15);box-shadow: 0 0 8px rgba(196,161,255,0.4);}
.theme-btn.blue{background:#12141d}
.theme-btn.pink{background:#19121d}
.theme-btn.green{background:#121d17}
.memory{background:#1b1e29;border-radius:12px;padding:12px;margin-bottom:20px}
.memory h4{color:#c4a1ff;margin-bottom:10px}
.mem-item{padding:6px 8px;background:#252a3a;border-radius:8px;margin-bottom:6px;font-size:12px;transition:all 0.2s ease;}
.mem-item:hover{background:#2d3242;padding-left:10px;}
.modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.95);background:#1b1e29;border-radius:16px;padding:20px;width:90%;max-width:380px;z-index:99;display:none;opacity:0;transition:opacity 0.3s ease, transform 0.3s ease;}
.modal.show{display:block;transform:translate(-50%,-50%);opacity:1;}
.modal input{width:100%;padding:12px;border-radius:10px;background:#252a3a;border:none;color:#fff;margin:10px 0;transition:all 0.2s ease;}
.modal input:focus{outline:none;transform: scale(1.01);box-shadow: 0 0 0 2px rgba(196,161,255,0.35);}
.modal .btn{padding:10px;width:100%;background:#c4a1ff;color:#000;border:none;border-radius:10px;transition:transform 0.15s ease;}
.modal .btn:active{transform: scale(0.95);}
.toast{position:fixed;bottom:100px;left:50%;transform:translate(-50%,20px);background:#1b1e29;color:#c4a1ff;padding:10px 16px;border-radius:8px;opacity:0;transition:.3s;z-index:100;}
.toast.show{opacity:1;transform:translate(-50%,0);animation: toastPop 0.3s ease forwards;}
.pages{width:100%}
.page{display:none}
.page.active{display:block}
.profile{background:#1b1e29;border-radius:12px;padding:16px;margin-bottom:16px}
.profile h4{color:#c4a1ff;margin-bottom:12px}
.stat{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #252a3a}
.fav-tag{background:#252a3a;padding:6px 10px;border-radius:8px;margin:4px;font-size:12px;transition:all 0.2s ease;}
.fav-tag:hover{background:#2d3242;transform: scale(1.03);}
.fav-tag .del{color:#ff6b6b;margin-left:6px;cursor:pointer}
.btn-group{display:flex;gap:10px;margin-top:10px}
.btn-sm{flex:1;padding:10px;border-radius:10px;border:none}
.btn-pri{background:#c4a1ff;color:#000}
.btn-danger{background:#ff4757;color:#fff}
/* 全局滚动条美化 */
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-thumb{background:#c4a1ff;border-radius:4px;}
::-webkit-scrollbar-track{background:#202431;}
/* 复制成功提示（全局） */
.toast-global{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#c4a1ff;color:#000;padding:8px 16px;border-radius:6px;font-size:14px;z-index:9999;opacity:0;transition:opacity 0.3s;}
.toast-global.show{opacity:1;animation: toastPop 0.3s ease forwards;}
/* 清空按钮样式 */
.clear-history,.clear-fav{background:#333;color:#fff;border:none;padding:4px 10px;border-radius:4px;font-size:12px;cursor:pointer;margin:5px 0;}
.clear-history:hover,.clear-fav:hover{background:#ff4d4d;}
.clear-fav{margin:5px 0 5px 10px;}
/* 全局顺滑滚动 */
html{scroll-behavior: smooth;}
/* 移动端禁止双击缩放 */
*{touch-action: manipulation;}
/* 返回顶部按钮 */
.back-top{position:fixed;bottom:20px;right:20px;width:40px;height:40px;background:#c4a1ff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;opacity:0;pointer-events:none;transition:opacity 0.3s;z-index:999;}
.back-top.show{opacity:1;pointer-events: all;}
/* 工具搜索框（修复z-index，让侧边栏能覆盖它） */
.search-box{padding:10px 15px;position:sticky;top:0;background:inherit;z-index:30;}
.search-input{width:100%;padding:10px 15px;border:1px solid #ddd;border-radius:30px;outline:none;font-size:14px;}
/* 主题切换按钮 */
.theme-toggle{position:fixed;top:20px;right:20px;width:40px;height:40px;border-radius:50%;background:#c4a1ff;display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:999;font-size:16px;}
/* 分类快捷标签栏 */
.category-tab{display:flex;gap:8px;padding:10px 15px;overflow-x:auto;background:inherit;border-bottom:1px solid #eee;z-index:30;}
.category-tab span{padding:6px 12px;border-radius:15px;background:#f0f0f0;white-space:nowrap;cursor:pointer;font-size:12px;}
.category-tab span.active{background:#c4a1ff;color:#000;}
/* 结果展示框 */
.result-box{white-space:pre-wrap;word-break:break-all;max-height:300px;overflow-y:auto;padding:10px;border-radius:8px;background:#f9f9f9;margin-top:10px;}
/* 版本信息 */
.version-info{position:fixed;bottom:70px;right:20px;padding:8px 12px;background:#222;color:#fff;border-radius:6px;font-size:12px;z-index:99;cursor:pointer;}
/* 网络工具面板 */
.tool-panel{margin:10px 0;padding:10px;border-radius:8px;background:#f5f5f5;z-index:30;}
.tool-panel button{padding:6px 10px;border-radius:6px;border:none;background:#c4a1ff;cursor:pointer;margin:4px;font-size:12px;}
.tool-panel button:hover{opacity:0.9;}
/* 网络工具结果输出 */
.result-output{padding:10px;margin:8px 0;border-radius:6px;background:#fff;color:#222;white-space:pre-wrap;word-break:break-all;max-height:300px;overflow-y:auto;}
/* 搜索无结果提示 */
.no-result{padding:20px;text-align:center;display:none;}
/* 动画 */
@keyframes pageFadeIn{from {opacity:0;} to {opacity:1;}}
@keyframes toastPop{from {transform: translate(-50%, 10px);opacity:0;} to {transform: translate(-50%, 0);opacity:1;}}
/* 系统深色模式适配 */
@media (prefers-color-scheme: dark) {
  body:not(.theme-pink):not(.theme-green){background:#121212;color:#eee;}
  body:not(.theme-pink):not(.theme-green) .card{background:#1e1e1e;}
  body:not(.theme-pink):not(.theme-green) .sidebar{background:#1a1a1a;}
}
</style>
</head>
<body>
<div class="overlay" id="overlay"></div>
<div class="sidebar" id="sidebar">
  <div class="close" id="closeSidebar">✕</div>
  <h2>Cyber Toolbox</h2>
  <div class="theme-switch">
    <div class="theme-btn blue" data-theme="blue"></div>
    <div class="theme-btn pink" data-theme="pink"></div>
    <div class="theme-btn green" data-theme="green"></div>
  </div>
  <div class="menu-item" data-page="home">首页</div>
  <div class="menu-item" data-cat="文本处理">文本处理</div>
  <div class="menu-item" data-cat="编码加密">编码加密</div>
  <div class="menu-item" data-cat="网络工具">网络工具</div>
  <div class="menu-item" data-cat="玩机助手">玩机助手</div>
  <div class="menu-item" data-cat="趣味整活">趣味整活</div>
  <div class="menu-item" data-cat="二次元">二次元游戏</div>
  <div class="menu-item" data-cat="计算工具">数学计算</div>
  <div class="menu-item" data-cat="逆向工具">安卓逆向</div>
  <div class="menu-item" data-cat="日常工具">日常实用</div>
  <div class="menu-item" data-cat="游戏辅助">游戏辅助</div>
  <div class="menu-item" data-cat="安全工具">网络安全</div>
  <div class="menu-item" data-cat="日常拓展">日常拓展</div>
  <div class="menu-item" data-cat="安全进阶">安全进阶</div>
  <div class="menu-item" data-cat="进制拓展">进制拓展</div>
  <div class="menu-item" data-cat="趣味进阶">趣味进阶</div>
  <div class="menu-item" data-cat="玩机进阶">玩机进阶</div>
  <div class="menu-item" data-page="me">我的</div>
</div>
<div class="header">
  <div class="menu" id="openSidebar">☰</div>
  <div class="title">全能工具箱 Max Pro</div>
  <div style="width:40px"></div>
</div>
<div class="main">
<div class="pages">
  <!-- 首页 -->
  <div class="page active" id="page-home">
    <div class="memory">
      <h4>🕒 最近使用</h4>
      <div id="memList"></div>
    </div>
    <div class="section"><h3>文本处理</h3><div class="grid">
      <div class="card tool" data-name="文本翻转"><div class="name">文本翻转</div></div>
      <div class="card tool" data-name="字数统计"><div class="name">字数统计</div></div>
      <div class="card tool" data-name="去重复行"><div class="name">去重复行</div></div>
      <div class="card tool" data-name="大写转小写"><div class="name">大写转小写</div></div>
      <div class="card tool" data-name="小写转大写"><div class="name">小写转大写</div></div>
      <div class="card tool" data-name="首字母大写"><div class="name">首字母大写</div></div>
      <div class="card tool" data-name="去除空格"><div class="name">去除空格</div></div>
      <div class="card tool" data-name="去除空行"><div class="name">去除空行</div></div>
      <div class="card tool" data-name="竖排文本"><div class="name">竖排文本</div></div>
    </div></div>
    <div class="section"><h3>编码加密</h3><div class="grid">
      <div class="card tool" data-name="MD5"><div class="name">MD5</div></div>
      <div class="card tool" data-name="SHA256"><div class="name">SHA256</div></div>
      <div class="card tool" data-name="Base64编码"><div class="name">Base64编码</div></div>
      <div class="card tool" data-name="Base64解码"><div class="name">Base64解码</div></div>
      <div class="card tool" data-name="URL编码"><div class="name">URL编码</div></div>
      <div class="card tool" data-name="摩斯编码"><div class="name">摩斯编码</div></div>
      <div class="card tool" data-name="凯撒密码"><div class="name">凯撒密码</div></div>
      <div class="card tool" data-name="Unicode编码"><div class="name">Unicode编码</div></div>
    </div></div>
  </div>
  <!-- 全部工具 -->
  <div class="page" id="page-tools">
    <div class="section" id="cat-文本处理"><h3>全文本工具(20)</h3><div class="grid">
      <div class="card tool" data-name="文本翻转"><div class="name">文本翻转</div></div>
      <div class="card tool" data-name="字数统计"><div class="name">字数统计</div></div>
      <div class="card tool" data-name="去重复行"><div class="name">去重复行</div></div>
      <div class="card tool" data-name="大写转小写"><div class="name">大写转小写</div></div>
      <div class="card tool" data-name="小写转大写"><div class="name">小写转大写</div></div>
      <div class="card tool" data-name="首字母大写"><div class="name">首字母大写</div></div>
      <div class="card tool" data-name="去除空格"><div class="name">去除空格</div></div>
      <div class="card tool" data-name="去除空行"><div class="name">去除空行</div></div>
      <div class="card tool" data-name="竖排文本"><div class="name">竖排文本</div></div>
      <div class="card tool" data-name="繁简转换"><div class="name">繁简转换</div></div>
      <div class="card tool" data-name="英文转中文"><div class="name">英文转中文</div></div>
      <div class="card tool" data-name="中文转拼音"><div class="name">中文转拼音</div></div>
      <div class="card tool" data-name="字符串拼接"><div class="name">字符串拼接</div></div>
      <div class="card tool" data-name="插入分隔符"><div class="name">插入分隔符</div></div>
      <div class="card tool" data-name="统计行数"><div class="name">统计行数</div></div>
      <div class="card tool" data-name="逆序段落"><div class="name">逆序段落</div></div>
      <div class="card tool" data-name="全角转半角"><div class="name">全角转半角</div></div>
      <div class="card tool" data-name="半角转全角"><div class="name">半角转全角</div></div>
      <div class="card tool" data-name="文本对比"><div class="name">文本对比</div></div>
      <div class="card tool" data-name="随机打乱文本"><div class="name">随机打乱文本</div></div>
    </div></div>
    <div class="section" id="cat-编码加密"><h3>全编码加密(18)</h3><div class="grid">
      <div class="card tool" data-name="MD5"><div class="name">MD5</div></div>
      <div class="card tool" data-name="SHA1"><div class="name">SHA1</div></div>
      <div class="card tool" data-name="SHA256"><div class="name">SHA256</div></div>
      <div class="card tool" data-name="SHA512"><div class="name">SHA512</div></div>
      <div class="card tool" data-name="SM3"><div class="name">SM3</div></div>
      <div class="card tool" data-name="Base64编码"><div class="name">Base64编码</div></div>
      <div class="card tool" data-name="Base64解码"><div class="name">Base64解码</div></div>
      <div class="card tool" data-name="URL编码"><div class="name">URL编码</div></div>
      <div class="card tool" data-name="URL解码"><div class="name">URL解码</div></div>
      <div class="card tool" data-name="Unicode编码"><div class="name">Unicode编码</div></div>
      <div class="card tool" data-name="Unicode解码"><div class="name">Unicode解码</div></div>
      <div class="card tool" data-name="HTML编码"><div class="name">HTML编码</div></div>
      <div class="card tool" data-name="HTML解码"><div class="name">HTML解码</div></div>
      <div class="card tool" data-name="摩斯编码"><div class="name">摩斯编码</div></div>
      <div class="card tool" data-name="摩斯解码"><div class="name">摩斯解码</div></div>
      <div class="card tool" data-name="凯撒密码"><div class="name">凯撒密码</div></div>
      <div class="card tool" data-name="栅栏密码"><div class="name">栅栏密码</div></div>
      <div class="card tool" data-name="RC4加密"><div class="name">RC4加密</div></div>
    </div></div>
    <div class="section" id="cat-进制转换"><h3>进制转换(6)</h3><div class="grid">
      <div class="card tool" data-name="十进制转二进制"><div class="name">十进制转二进制</div></div>
      <div class="card tool" data-name="十进制转八进制"><div class="name">十进制转八进制</div></div>
      <div class="card tool" data-name="十进制转十六进制"><div class="name">十进制转十六进制</div></div>
      <div class="card tool" data-name="二进制转十进制"><div class="name">二进制转十进制</div></div>
      <div class="card tool" data-name="八进制转十进制"><div class="name">八进制转十进制</div></div>
      <div class="card tool" data-name="十六进制转十进制"><div class="name">十六进制转十进制</div></div>
    </div></div>
    <div class="section" id="cat-网络工具"><h3>网络工具(12)</h3><div class="grid">
      <div class="card tool" data-name="IP查询"><div class="name">IP查询</div></div>
      <div class="card tool" data-name="DNS解析"><div class="name">DNS解析</div></div>
      <div class="card tool" data-name="端口检测"><div class="name">端口检测</div></div>
      <div class="card tool" data-name="UA解析"><div class="name">UA解析</div></div>
      <div class="card tool" data-name="时间戳转日期"><div class="name">时间戳转日期</div></div>
      <div class="card tool" data-name="日期转时间戳"><div class="name">日期转时间戳</div></div>
      <div class="card tool" data-name="GET请求模拟"><div class="name">GET模拟</div></div>
      <div class="card tool" data-name="POST请求模拟"><div class="name">POST模拟</div></div>
      <div class="card tool" data-name="网络延迟测试"><div class="name">延迟测试</div></div>
      <div class="card tool" data-name="WiFi信号模拟"><div class="name">WiFi信号</div></div>
      <div class="card tool" data-name="短链接生成"><div class="name">短链接</div></div>
      <div class="card tool" data-name="链接解封"><div class="name">链接解封</div></div>
    </div></div>
    <div class="section" id="cat-玩机助手"><h3>玩机助手(8)</h3><div class="grid">
      <div class="card tool" data-name="ADB命令生成"><div class="name">ADB生成</div></div>
      <div class="card tool" data-name="Magisk模块生成"><div class="name">Magisk模块</div></div>
      <div class="card tool" data-name="Frida脚本模板"><div class="name">Frida模板</div></div>
      <div class="card tool" data-name="ROOT权限检测"><div class="name">ROOT检测</div></div>
      <div class="card tool" data-name="刷机命令生成"><div class="name">刷机命令</div></div>
      <div class="card tool" data-name="APK信息解析"><div class="name">APK解析</div></div>
      <div class="card tool" data-name="SO文件信息"><div class="name">SO信息</div></div>
      <div class="card tool" data-name="安卓机型修改"><div class="name">机型修改</div></div>
    </div></div>
    <div class="section" id="cat-趣味整活"><h3>趣味整活(6)</h3><div class="grid">
      <div class="card tool" data-name="装逼语录生成"><div class="name">装逼语录</div></div>
      <div class="card tool" data-name="土味情话生成"><div class="name">土味情话</div></div>
      <div class="card tool" data-name="骂人文明转换器"><div class="name">文明用语</div></div>
      <div class="card tool" data-name="随机表情包文案"><div class="name">表情包文案</div></div>
      <div class="card tool" data-name="朋友圈文案生成"><div class="name">朋友圈文案</div></div>
      <div class="card tool" data-name="整蛊弹窗代码"><div class="name">整蛊代码</div></div>
    </div></div>
    <div class="section" id="cat-二次元游戏"><h3>二次元游戏(4)</h3><div class="grid">

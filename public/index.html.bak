<div class="modal" id="modal">
  <div id="mTitle"></div>
  <input id="mInput" placeholder="请输入内容（多参数用英文逗号分隔）">
  <button class="btn" id="run">执行</button>
</div>
<div class="toast" id="toast"></div>

// ========== 新增优化功能 小白专用 ==========
// 1. 弹窗输入框按回车直接执行
document.getElementById('mInput').addEventListener('keypress', function(e) {
  if(e.key === 'Enter') {
    document.getElementById('run').click();
  }
});

// 2. 点击提示条自动复制结果
let lastToolResult = '';
document.getElementById('toast').onclick = function() {
  if(!lastToolResult) return;
  navigator.clipboard.writeText(lastToolResult).then(function() {
    showToast('结果已复制！');
  }).catch(function() {
    showToast('复制失败');
  });
};

// 3. 优化showToast，记录结果用于复制
const oldShowToast = showToast;
function showToast(msg) {
  lastToolResult = msg;
  oldShowToast(msg);
}

// 4. 双击标题快速回顶部
document.querySelectorAll('.section h3').forEach(function(item) {
  item.ondblclick = function() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };
});
// 新增：点击最近使用记录，直接打开对应工具
document.addEventListener('click', function(e) {
  if(e.target.classList.contains('mem-item')) {
    const toolName = e.target.textContent.trim();
    openTool(toolName);
  }
});
// 新增：执行工具后自动清空输入框
const oldRunClick = document.getElementById('run').onclick;
document.getElementById('run').onclick = async function() {
  await oldRunClick();
  document.getElementById('mInput').value = '';
};
// 新增：主题记忆功能，刷新不丢失
document.addEventListener('DOMContentLoaded', function() {
  // 读取本地保存的主题
  const savedTheme = localStorage.getItem('toolboxTheme');
  if (savedTheme) {
    document.body.className = 'theme-' + savedTheme;
  }

  // 重写主题切换，保存到本地
  document.querySelectorAll('.theme-btn').forEach(btn => {
    const oldClick = btn.onclick;
    btn.onclick = function() {
      oldClick();
      const theme = this.dataset.theme;
      localStorage.setItem('toolboxTheme', theme);
    }
  });
});
// 新增：工具弹窗自动显示输入提示
const toolPlaceholder = {
  '十进制转二进制': '请输入数字',
  '八进制转二进制': '请输入数字',
  '十六进制转二进制': '请输入数字',
  '最大数计算': '数字用英文逗号分隔，如10,20,30',
  '求和计算': '数字用英文逗号分隔，如10,20,30',
  '税率计算': '金额,税率，如1000,5',
  '利息计算': '本金,利率,期数，如10000,3,12',
  '年龄计算': '请输入出生年份，如2008',
  '银行卡号校验': '请输入银行卡号',
  '车牌号校验': '请输入车牌号'
};

const oldOpenTool = openTool;
function openTool(name) {
  oldOpenTool(name);
  const input = document.getElementById('mInput');
  input.placeholder = toolPlaceholder[name] || '请输入内容（多参数用英文逗号）';
}
// 新增：双击页面空白处一键关闭弹窗+侧边栏
document.addEventListener('dblclick', function(e) {
  if(e.target === document.body) {
    closeAll();
  }
});
// 新增：长按工具卡片快速收藏
let pressTimer = null;
document.querySelectorAll('.card').forEach(card => {
  // 长按开始
  card.addEventListener('touchstart', function() {
    pressTimer = setTimeout(() => {
      const toolName = this.textContent.trim();
      if(confirm('确定收藏【'+toolName+'】吗？')) {
        showToast('已收藏：'+toolName);
      }
    }, 800);
  });
  // 松开取消
  card.addEventListener('touchend', () => clearTimeout(pressTimer));
  card.addEventListener('touchmove', () => clearTimeout(pressTimer));
});
// 新增：按ESC键关闭弹窗
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    // 关闭弹窗
    const modal = document.querySelector('.modal.show');
    if (modal) {
      modal.classList.remove('show');
    }
    // 同时清空输入框
    document.getElementById('mInput').value = '';
  }
});
/* 优化8：页面加载淡入效果 */
body {
  animation: pageFadeIn 0.5s ease forwards;
}
@keyframes pageFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
// 防止执行按钮重复点击
let isRunning = false;
const originalRun = document.getElementById('run').onclick;
document.getElementById('run').onclick = async function(e) {
  if(isRunning) return;
  isRunning = true;
  await originalRun(e);
  isRunning = false;
};
// 新增：输入框按回车直接执行工具
document.getElementById('mInput').addEventListener('keypress', function(e) {
  if(e.key === 'Enter') {
    document.getElementById('run').click();
  }
});
// 新增：工具使用次数统计（本地）
function countToolUse(name) {
  let count = localStorage.getItem('tool_count_' + name) || 0;
  count = parseInt(count) + 1;
  localStorage.setItem('tool_count_' + name, count);
}

// 每次打开工具就计数
const originOpenTool = openTool;
function openTool(name) {
  originOpenTool(name);
  countToolUse(name);
}
// 复制成功提示函数
function showToast(msg) {
  let toast = document.querySelector('.toast');
  if (!toast) {
    toast = document.createElement('div');
    toast.className = 'toast';
    document.body.appendChild(toast);
  }
  toast.textContent = msg;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 1200);
}

// 执行后自动复制结果并提示
const oldRun = document.getElementById('run').onclick;
document.getElementById('run').onclick = async function() {
  const res = await oldRun();
  if (res) {
    navigator.clipboard.writeText(res).then(() => {
      showToast('已复制结果');
    });
  }
};
// 新增：一键清空最近使用
function clearRecent() {
  if(confirm('确定清空所有最近使用记录吗？')) {
    localStorage.removeItem('recent_tools');
    document.querySelector('.recent-list').innerHTML = '<div>暂无最近使用</div>';
    showToast('已清空最近使用');
  }
}

// 在我的页面加载时显示清空按钮
const oldOpenMy = openMy;
function openMy() {
  oldOpenMy();
  const myPage = document.querySelector('.my-page');
  if(!myPage.querySelector('.clear-history')) {
    const btn = document.createElement('button');
    btn.className = 'clear-history';
    btn.textContent = '清空最近使用';
    btn.onclick = clearRecent;
    myPage.insertBefore(btn, myPage.firstChild);
  }
}
// 新增：一键清空收藏
function clearFavorite() {
  if(confirm('确定清空所有收藏工具吗？')) {
    localStorage.removeItem('favorite_tools');
    document.querySelector('.fav-list').innerHTML = '<div>暂无收藏</div>';
    showToast('已清空收藏');
  }
}

// 打开我的页面时显示清空收藏按钮
const oldOpenMy2 = openMy;
function openMy() {
  oldOpenMy2();
  const myPage = document.querySelector('.my-page');
  if(!myPage.querySelector('.clear-fav')) {
    const btn = document.createElement('button');
    btn.className = 'clear-fav';
    btn.textContent = '清空收藏';
    btn.onclick = clearFavorite;
    myPage.insertBefore(btn, myPage.firstChild);
  }
}
// 系统深色模式自动适配
const media = window.matchMedia('(prefers-color-scheme: dark)');
media.addEventListener('change', e => {
  document.body.classList.toggle('system-dark', e.matches);
});
// 打开工具时高亮对应卡片
const oldOpenTool2 = openTool;
function openTool(name) {
  // 清除旧高亮
  document.querySelectorAll('.card').forEach(c => c.classList.remove('active'));
  // 设置新高亮
  document.querySelectorAll('.card').forEach(c => {
    if(c.textContent.trim() === name) c.classList.add('active');
  });
  oldOpenTool2(name);
}
// 输入为空时提示
const oldRunCheck = document.getElementById('run').onclick;
document.getElementById('run').onclick = async function() {
  const val = document.getElementById('mInput').value.trim();
  if (!val) {
    showToast('请先输入内容');
    return;
  }
  return await oldRunCheck();
};
// 优化20：点击按钮震动反馈
document.addEventListener('click', function(e) {
  if(e.target.tagName === 'BUTTON' || e.target.classList.contains('card') || e.target.classList.contains('menu')) {
    if(navigator.vibrate) navigator.vibrate(20);
  }
});
// 返回顶部功能
const backTop = document.createElement('div');
backTop.className = 'back-top';
backTop.innerHTML = '↑';
document.body.appendChild(backTop);

backTop.onclick = () => window.scrollTo(0,0);

window.addEventListener('scroll', () => {
  backTop.classList.toggle('show', window.scrollY > 300);
});
// 新增搜索框
const searchWrap = document.createElement('div');
searchWrap.className = 'search-box';
const searchInput = document.createElement('input');
searchInput.className = 'search-input';
searchInput.placeholder = '搜索工具名称...';
searchWrap.appendChild(searchInput);
document.body.insertBefore(searchWrap, document.body.firstChild);

// 搜索功能
searchInput.oninput = function() {
  const key = this.value.toLowerCase();
  document.querySelectorAll('.card').forEach(card => {
    const name = card.textContent.toLowerCase();
    card.style.display = name.includes(key) ? 'block' : 'none';
  });
};
// 搜索无结果提示
const noResult = document.createElement('div');
noResult.style.display = 'none';
noResult.style.padding = '20px';
noResult.style.textAlign = 'center';
noResult.textContent = '未找到相关工具';
document.querySelector('.container').appendChild(noResult);

const originSearch = searchInput.oninput;
searchInput.oninput = function() {
  originSearch.call(this);
  const total = document.querySelectorAll('.card').length;
  const hidden = document.querySelectorAll('.card[style="display: none;"]').length;
  noResult.style.display = total === hidden ? 'block' : 'none';
};
// 主题切换
const themeBtn = document.createElement('div');
themeBtn.className = 'theme-toggle';
themeBtn.textContent = '🌙';
document.body.appendChild(themeBtn);

themeBtn.onclick = () => {
  document.body.classList.toggle('dark');
  localStorage.setItem('dark_mode', document.body.classList.contains('dark'));
  themeBtn.textContent = document.body.classList.contains('dark') ? '☀️' : '🌙';
};

// 记住上次主题
if(localStorage.getItem('dark_mode') === 'true') {
  document.body.classList.add('dark');
  themeBtn.textContent = '☀️';
}
// 长按复制工具名称
document.querySelectorAll('.card').forEach(card => {
  let longPress;
  card.addEventListener('touchstart', () => {
    longPress = setTimeout(() => {
      const name = card.textContent.trim();
      navigator.clipboard.writeText(name).then(() => {
        showToast('已复制：' + name);
      });
    }, 1000);
  });
  card.addEventListener('touchend', () => clearTimeout(longPress));
  card.addEventListener('touchmove', () => clearTimeout(longPress));
});
// 分类快捷标签栏
const catTab = document.createElement('div');
catTab.className = 'category-tab';
const cats = ['全部','常用','逆向','系统','网络','其他'];
cats.forEach(c => {
  const s = document.createElement('span');
  s.textContent = c;
  s.onclick = () => {
    document.querySelectorAll('.category-tab span').forEach(t=>t.classList.remove('active'));
    s.classList.add('active');
    showToast('切换至：'+c);
  };
  catTab.appendChild(s);
});
document.querySelector('.search-box').after(catTab);
// 结果美观展示
function showResult(text) {
  let box = document.querySelector('.result-box');
  if(!box) {
    box = document.createElement('div');
    box.className = 'result-box';
    document.getElementById('run').after(box);
  }
  box.textContent = text;
}
// 输入历史记录
let inputHistory = JSON.parse(localStorage.getItem('input_history')||'[]');
let histIndex = -1;
document.getElementById('mInput').addEventListener('keydown',e=>{
  if(e.key==='ArrowUp'){
    e.preventDefault();
    if(histIndex<inputHistory.length-1) histIndex++;
    if(inputHistory[histIndex]) document.getElementById('mInput').value = inputHistory[histIndex];
  }
  if(e.key==='ArrowDown'){
    e.preventDefault();
    histIndex = Math.max(-1, histIndex-1);
    document.getElementById('mInput').value = histIndex==-1?'':inputHistory[histIndex]||'';
  }
});
// 保存历史
const oldRunHist = document.getElementById('run').onclick;
document.getElementById('run').onclick=async ()=>{
  const v = document.getElementById('mInput').value.trim();
  if(v && !inputHistory.includes(v)){
    inputHistory.unshift(v);
    inputHistory = inputHistory.slice(0,20);
    localStorage.setItem('input_history',JSON.stringify(inputHistory));
  }
  histIndex = -1;
  return await oldRunHist();
};

<script>
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('overlay');
const modal   = document.getElementById('modal');
const toast   = document.getElementById('toast');
let currTool  = '';

function showToast(m){
  toast.textContent = m;
  toast.classList.add('show');
  setTimeout(()=>toast.classList.remove('show'), 1800);
}

function closeAll(){
  sidebar.classList.remove('show');
  overlay.classList.remove('show');
  modal.classList.remove('show');
}

document.getElementById('openSidebar').onclick = () => {
  sidebar.classList.add('show');
  overlay.classList.add('show');
}
document.getElementById('closeSidebar').onclick = closeAll;
overlay.onclick = closeAll;

async function loadMem(){
  const d = await (await fetch('/api/memory')).json();
  document.getElementById('memList').innerHTML = d.data.map(i=>`<div class="mem-item">${i.tool}</div>`).join('');
}

async function loadStat(){
  const d = await (await fetch('/api/stats')).json();
  const t = Object.values(d.data).reduce((a,b)=>a+b,0);
  let h = `<div class="stat"><span>总次数</span><span>${t}</span></div>`;
  Object.entries(d.data).forEach(([k,v])=>{
    h+=`<div class="stat"><span>${k}</span><span>${v}</span></div>`;
  });
  document.getElementById('statList').innerHTML = h;
}

async function loadFav(){
  const d = await (await fetch('/api/favorites')).json();
  if(d.data.length===0){
    document.getElementById('favList').innerHTML = '暂无收藏，长按工具收藏';
    return;
  }
  document.getElementById('favList').innerHTML = d.data.map(i=>`
    <span class="fav-tag">${i}<span class="del" onclick="delFav('${i}')">×</span></span>
  `).join('');
}

window.delFav = async (name)=>{
  await fetch('/api/fav',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({name,act:'del'})
  });
  loadFav();
  showToast('已取消收藏');
}

document.querySelectorAll('.bottom-nav .item').forEach(i=>{
  i.onclick = ()=>{
    document.querySelectorAll('.bottom-nav .item').forEach(e=>e.classList.remove('active'));
    i.classList.add('active');
    const p = i.dataset.page;
    document.querySelectorAll('.page').forEach(e=>e.classList.remove('active'));
    document.getElementById('page-'+p).classList.add('active');
    if(p==='me'){ loadMem(); loadStat(); loadFav(); }
    closeAll();
  }
});

function openTool(name){
  currTool = name;
  document.getElementById('mTitle').textContent = name;
  document.getElementById('mInput').value = '';
  modal.classList.add('show');
  overlay.classList.add('show');
}

document.getElementById('run').onclick = async ()=>{
  const c = document.getElementById('mInput').value;
  const res = await fetch('/api/run',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({tool:currTool,c})
  });
  const d = await res.json();
  showToast(d.data || d.msg);
  closeAll();
  loadMem();
}

document.querySelectorAll('.tool').forEach(el=>{
  let timer;
  el.ontouchstart = ()=>{
    timer = setTimeout(()=>{
      fetch('/api/fav',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({name:el.dataset.name,act:'add'})
      });
      showToast('已收藏');
      loadFav();
    }, 600);
  }
  el.ontouchend = ()=> clearTimeout(timer);
  el.onclick = ()=> openTool(el.dataset.name);
});

document.querySelectorAll('.menu-item').forEach(i=>{
  i.onclick = ()=>{
    if(i.dataset.page){
      document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
      document.getElementById('page-'+i.dataset.page).classList.add('active');
      if(i.dataset.page==='me'){ loadMem(); loadStat(); loadFav(); }
    }else{
      const cat = i.dataset.cat;
      showToast('已切换至 '+cat);
      document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
      document.getElementById('page-tools').classList.add('active');
      document.querySelectorAll('.bottom-nav .item').forEach(e=>e.classList.remove('active'));
      document.querySelectorAll('.bottom-nav .item')[1].classList.add('active');
      const target = document.getElementById(`cat-${cat}`);
      if(target) target.scrollIntoView({behavior:'smooth'});
    }
    closeAll();
  }
});

document.querySelectorAll('.theme-btn').forEach(b=>{
  b.onclick = ()=>{
    document.body.className = 'theme-'+b.dataset.theme;
    showToast('已切换主题');
  }
});

document.getElementById('export').onclick = async ()=>{
  const d = await (await fetch('/api/export')).json();
  const blob = new Blob([JSON.stringify(d.data)],{type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'toolbox-data.json';
  a.click();
  URL.revokeObjectURL(url);
  showToast('导出成功');
}

document.getElementById('clear').onclick = async ()=>{
  await fetch('/api/clear',{method:'POST'});
  loadMem();
  loadStat();
  loadFav();
  showToast('已清空所有数据');
}

loadMem();
</script>
</body>
</html>
